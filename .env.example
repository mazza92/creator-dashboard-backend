# Copy relevant keys into your local .env (do not commit real secrets).

# --- Social scraping (in-house only; Apify removed) ---
# Optional but recommended for Instagram reliability when guest HTML is login-walled.
# Paste the `sessionid` cookie value from a logged-in instagram.com browser session.
# INSTAGRAM_SESSIONID=
# IG_SESSIONID=

# Absolute API origin for /api/media-proxy image URLs (required in production so
# app.newcollab.co never loads thumbs from the wrong host).
# PUBLIC_API_URL=https://api.newcollab.co

# Gemini (post-scrape niche / aesthetic analysis)
GEMINI_API_KEY=
